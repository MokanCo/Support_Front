# Base URL of the API server (no trailing slash). The app forwards /api/... to the same path on this host.
BACKEND_API_URL=http://localhost:5000

# Socket.IO origin for the browser (path /socket.io). Optional: next.config copies BACKEND_API_URL here if unset.
# NEXT_PUBLIC_SOCKET_URL=http://localhost:5000

# Must match the backend JWT secret so middleware can verify Bearer tokens.
JWT_SECRET=replace-with-at-least-32-characters
